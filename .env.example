# ─────────────────────────────────────────────────────────────────────────────
#  Copie ce fichier en ".env" et remplis tes valeurs.
#  NE JAMAIS committer le fichier .env dans Git !
# ─────────────────────────────────────────────────────────────────────────────

# Token de ton bot Discord (obtenu sur https://discord.com/developers)
DISCORD_TOKEN=ton_token_discord_ici

# URL du serveur Ollama principal (résolu automatiquement dans docker-compose)
OLLAMA_PRIMARY_URL=http://ollama-main:11434

# URL du serveur Ollama backup (machine externe — remplace par ton IP ou hostname)
OLLAMA_BACKUP_URL=http://192.168.1.XXX:11434

# Modèle Ollama à utiliser (doit être pulled sur le serveur)
OLLAMA_MODEL=llama3

# Timeout en secondes pour les requêtes vers Ollama
OLLAMA_TIMEOUT=60
